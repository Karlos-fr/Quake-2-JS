{
  "name": "quake2js",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @quake2js/web",
    "build": "npm run build --workspace @quake2js/web",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "index:c-sources": "node ./tools/c-analyzer/index-source-tree.mjs",
    "extract:c-signatures": "node ./tools/c-analyzer/extract-signatures.mjs",
    "generate:ts-stubs": "node ./tools/stub-generator/generate-ts-stubs.mjs",
    "map:c-to-ts": "node ./tools/c-analyzer/build-source-module-map.mjs",
    "golden:pak0:write": "npx tsx ./scripts/verify/golden-pak-summary.mjs --write",
    "golden:pak0": "npx tsx ./scripts/verify/golden-pak-summary.mjs"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/three": "^0.184.0",
    "three": "^0.184.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.8"
  }
}
