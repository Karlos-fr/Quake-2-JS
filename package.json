{
  "name": "quake2js",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @quake2js/web",
    "build": "npm run build --workspace @quake2js/web",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "index:c-sources": "node ./tools/c-analyzer/index-source-tree.mjs",
    "extract:c-signatures": "node ./tools/c-analyzer/extract-signatures.mjs",
    "generate:ts-stubs": "node ./tools/stub-generator/generate-ts-stubs.mjs",
    "map:c-to-ts": "node ./tools/c-analyzer/build-source-module-map.mjs",
    "golden:pak0:write": "npx tsx ./scripts/verify/golden-pak-summary.mjs --write",
    "golden:pak0": "npx tsx ./scripts/verify/golden-pak-summary.mjs",
    "verify:doors:phase1": "npx tsx ./scripts/verify/quake2-door-phase1.ts",
    "verify:doors:phase2": "npx tsx ./scripts/verify/quake2-door-phase2.ts",
    "verify:doors:phase3": "npx tsx ./scripts/verify/quake2-door-phase3.ts",
    "verify:doors:phase4": "npx tsx ./scripts/verify/quake2-door-phase4.ts",
    "verify:doors:phase5": "npx tsx ./scripts/verify/quake2-door-phase5.ts",
    "verify:doors:phase6": "npx tsx ./scripts/verify/quake2-door-phase6.ts",
    "verify:doors:phase7": "npx tsx ./scripts/verify/quake2-door-phase7.ts",
    "verify:collision:phase1": "npx tsx ./scripts/verify/quake2-collision-phase1.ts",
    "verify:collision:phase2": "npx tsx ./scripts/verify/quake2-collision-phase2.ts",
    "verify:collision:phase3": "npx tsx ./scripts/verify/quake2-collision-phase3.ts",
    "verify:collision:phase4": "npx tsx ./scripts/verify/quake2-collision-phase4.ts",
    "verify:collision:phase5": "npx tsx ./scripts/verify/quake2-collision-phase5.ts",
    "verify:collision:phase6": "npx tsx ./scripts/verify/quake2-collision-phase6.ts",
    "verify:collision:phase7": "npx tsx ./scripts/verify/quake2-collision-phase7.ts",
    "verify:collision:phase8": "npx tsx ./scripts/verify/quake2-collision-phase8.ts",
    "verify:collision:phase9": "npx tsx ./scripts/verify/quake2-collision-phase9.ts"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/three": "^0.184.0",
    "three": "^0.184.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.8"
  }
}
